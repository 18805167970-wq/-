generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  APPROVER
  ADMIN
}

enum ReimbursementStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

enum ApprovalStatus {
  APPROVED
  REJECTED
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String
  password   String
  role       Role     @default(EMPLOYEE)
  department String?
  phone      String?
  approverId String?
  approver   User?    @relation("UserApprover", fields: [approverId], references: [id])
  subordinates User[] @relation("UserApprover")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  reimbursements Reimbursement[]
  approvals      Approval[]
}

model Reimbursement {
  id                String              @id @default(cuid())
  userId            String
  user              User                @relation(fields: [userId], references: [id])
  month             String
  totalHotelFee     Decimal             @db.Decimal(10, 2)
  totalTransportFee Decimal             @db.Decimal(10, 2)
  totalAmount       Decimal             @db.Decimal(10, 2)
  status            ReimbursementStatus @default(PENDING)
  emailContent      String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  details   ReimbursementDetail[]
  approvals Approval[]
}

model ReimbursementDetail {
  id              String        @id @default(cuid())
  reimbursementId String
  reimbursement   Reimbursement @relation(fields: [reimbursementId], references: [id], onDelete: Cascade)
  date            DateTime
  destination     String
  reason          String
  transportTypes  String
  transportFee    Decimal       @db.Decimal(10, 2)
  hotelFee        Decimal       @db.Decimal(10, 2)
  remark          String?
}

model Approval {
  id              String         @id @default(cuid())
  reimbursementId String
  reimbursement   Reimbursement  @relation(fields: [reimbursementId], references: [id])
  approverId      String
  approver        User           @relation(fields: [approverId], references: [id])
  status          ApprovalStatus
  comment         String?
  createdAt       DateTime       @default(now())
}
